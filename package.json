{
  "name": "opc-agent",
  "version": "4.1.15",
  "description": "Open Agent Framework — Build, test, and run AI Agents for business workstations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "opc": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "xcopy /E /I /Y src\\studio-ui dist\\studio-ui",
    "test": "vitest run",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "setup": "opc setup",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "agent",
    "ai",
    "llm",
    "framework",
    "typescript",
    "agent-framework"
  ],
  "author": "Deepleaper",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Deepleaper/opc-agent.git"
  },
  "dependencies": {
    "agent-workstation": "^2.1.2",
    "agentkits": "^2.0.1",
    "commander": "^12.0.0",
    "express": "^4.21.0",
    "js-yaml": "^4.1.0",
    "mammoth": "^1.12.0",
    "pdf-parse": "^1.1.4",
    "sql.js": "^1.14.1",
    "ws": "^8.20.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/sql.js": "^1.4.11",
    "@types/ws": "^8.18.1",
    "typescript": "^5.5.0",
    "vitepress": "^1.5.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "deepbrain": "^2.0.5"
  },
  "peerDependenciesMeta": {
    "deepbrain": {
      "optional": true
    }
  }
}
